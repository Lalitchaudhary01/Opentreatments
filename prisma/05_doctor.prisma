// prisma/doctor.prisma
model IndependentDoctor {
  id                String                    @id @default(cuid())
  userId            String                    @unique
  firstName         String?
  lastName          String?
  phone             String?
  name              String
  medicalRegistrationNumber String?
  qualification     String?
  graduationYear    String?
  experienceLabel   String?
  clinicName        String?
  pinCode           String?
  address           String?
  specialties       String[]
  specialization    String
  experience        Int?
  gender            String?
  dob               DateTime?
  bio               String?
  medicalCouncil    String?
  profilePic        String?
  fees              Float?
  rating            Float                     @default(0)
  totalReviews      Int                       @default(0)
  languages         String[]
  availability      Json?
  badges            String[]
  city              String?
  status            DoctorStatus              @default(PENDING)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  consultations     IndependentConsultation[]
  services          DoctorService[]
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  IndependentReview IndependentReview[]
  offlineConsultations OfflineConsultation[]

  @@index([status, createdAt])
  @@index([city])
  @@index([specialization])
  @@map("DoctorProfile")
}

model DoctorService {
  id          String            @id @default(cuid())
  doctorId    String
  name        String
  category    String
  price       Float
  discountPrice Float?
  duration    Int
  description String?
  availability String
  isOnline    Boolean           @default(true)
  maxSlots    Int?
  tags        String[]          @default([])
  isActive    Boolean           @default(true)
  sessions    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  doctor      IndependentDoctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([doctorId, createdAt])
  @@index([doctorId, isActive])
  @@index([doctorId, category])
  @@index([doctorId, isOnline])
  @@map("DoctorServiceProfile")
}

model IndependentConsultation {
  id                String             @id @default(cuid())
  doctorId          String
  userId            String
  slot              DateTime
  duration          Int?
  status            ConsultationStatus @default(PENDING)
  mode              String             @default("online")
  fee               Float?
  paymentId         String?
  paymentStatus     String             @default("unpaid")
  notes             String?
  prescription      String?
  cancelReason      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  doctor            IndependentDoctor  @relation(fields: [doctorId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  IndependentReview IndependentReview?
  Payment           Payment?

  @@index([doctorId, slot])
  @@index([doctorId, status, slot])
  @@index([userId, createdAt])
  @@map("DoctorConsultation")
}

model OfflineConsultation {
  id             String   @id @default(cuid())
  doctorId       String
  patientName    String
  patientAge     Int?
  patientGender  String?
  phoneNumber    String?
  complaint      String
  prescription   String?   // Medicine/advice diya
  followUpDate   DateTime? // Next visit
  visitTime      DateTime @default(now())
  
  doctor         IndependentDoctor @relation(fields: [doctorId], references: [id])
  
  createdAt      DateTime @default(now())

  @@index([doctorId, visitTime])
  @@index([doctorId, createdAt])
  @@map("DoctorOfflineConsultation")
}

model IndependentReview {
  id             String                  @id @default(cuid())
  consultationId String                  @unique
  doctorId       String
  userId         String
  rating         Int
  feedback       String?
  createdAt      DateTime                @default(now())
  consultation   IndependentConsultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  doctor         IndependentDoctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([doctorId, createdAt])
  @@index([userId])
  @@map("DoctorReview")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model Payment {
  id             String                  @id @default(cuid())
  consultationId String                  @unique
  consultation   IndependentConsultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  labBookingId   String?                 @unique
  labBooking     LabBooking?             @relation("BookingPayment", fields: [labBookingId], references: [id])
  amount         Float
  status         PaymentStatus           @default(PENDING)
  provider       String?
  transactionId  String?
  createdAt      DateTime                @default(now())

  @@index([status, createdAt])
}

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  actionType String
  targetId   String
  targetType String
  details    String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}
