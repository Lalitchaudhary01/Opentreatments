// prisma/hospital.prisma
model Hospital {
  id         String         @id @default(cuid())
  name       String
  slug       String         @unique
  address    String?
  city       String?
  state      String?
  country    String?
  phone      String?
  email      String?
  website    String?
  logo       String?
  image      String?
  verified   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  status     HospitalStatus @default(PENDING)
  userId     String         @unique
  estimates  Estimate[]
  consultations HospitalConsultation[]
  offlineConsultations HospitalOfflineConsultation[]
 
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  services   Service[]

  @@index([status, createdAt])
  @@index([city])
  @@index([name])
  @@map("HospitalProfile")
}

model HospitalConsultation {
  id            String             @id @default(cuid())
  hospitalId    String
  userId        String
  slot          DateTime
  duration      Int?
  status        ConsultationStatus @default(PENDING)
  mode          String             @default("online")
  fee           Float?
  department    String?
  doctorName    String?
  notes         String?
  prescription  String?
  cancelReason  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  hospital      Hospital           @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hospitalId, slot])
  @@index([hospitalId, status, slot])
  @@index([userId, createdAt])
  @@map("HospitalConsultation")
}

model HospitalOfflineConsultation {
  id             String   @id @default(cuid())
  hospitalId     String
  patientName    String
  patientId      String?
  patientAge     Int?
  patientGender  String?
  phoneNumber    String?
  department     String?
  doctorName     String?
  consultationType String?
  complaint      String
  prescription   String?
  followUpDate   DateTime?
  visitTime      DateTime @default(now())
  createdAt      DateTime @default(now())
  hospital       Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId, visitTime])
  @@index([hospitalId, createdAt])
  @@index([hospitalId, patientId])
  @@map("HospitalOfflineConsultation")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  cost        Float?
  description String?
  hospitalId  String
  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([hospitalId, createdAt])
  @@map("HospitalService")
}

model Estimate {
  id            String    @id @default(cuid())
  policyId      String
  hospitalId    String
  procedureId   String
  procedureCost Float
  coveredAmount Float
  outOfPocket   Float
  createdAt     DateTime  @default(now())
  hospital      Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId, createdAt])
  @@index([policyId])
  @@index([procedureId])
  @@map("HospitalCoverageEstimate")
}
